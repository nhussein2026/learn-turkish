---
import '../styles/global.css';
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  lang?: 'en' | 'ar' | 'tr';
}

const { 
  title, 
  description = 'Learn Turkish — A comprehensive platform for learning Turkish from English or Arabic', 
  image,
  lang = 'en' 
} = Astro.props;
const dir = lang === 'ar' ? 'rtl' : 'ltr';

const navItems = [
  { href: '/', label: 'Home', icon: '🏠' },
  { href: '/words/', label: 'Vocabulary', icon: '📚' },
  { href: '/grammar/', label: 'Grammar', icon: '📐' },
  { href: '/suffixes/', label: 'Suffixes', icon: '🔗' },
  { href: '/search/', label: 'Search', icon: '🔍' },
  { href: '/practice/', label: 'Practice', icon: '🎯' },
  { href: '/dashboard/', label: 'Dashboard', icon: '📊' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang={lang} dir={dir} class="scroll-smooth">
  <head>
    <SEO title={title} description={description} image={image} />
  </head>
  <body class="bg-pattern min-h-screen flex flex-col">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-border-light">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 no-underline group">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary to-primary-dark flex items-center justify-center shadow-sm group-hover:shadow-glow transition-shadow">
            <span class="text-white font-bold text-sm font-[family-name:var(--font-heading)]">TR</span>
          </div>
          <div>
            <h1 class="text-base font-bold tracking-tight text-text leading-none">LEARN TURKISH</h1>
            <p class="text-[10px] text-text-muted uppercase tracking-[0.15em] font-semibold">Language Platform</p>
          </div>
        </a>

        <!-- Desktop Navigation -->
        <div class="hidden md:flex items-center gap-1">
          {navItems.map(item => (
            <a
              href={item.href}
              class:list={[
                'px-3 py-2 rounded-lg text-sm font-semibold transition-all no-underline',
                currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
                  ? 'bg-primary/8 text-primary'
                  : 'text-text-secondary hover:text-text hover:bg-surface-hover'
              ]}
            >
              {item.label}
            </a>
          ))}
        </div>

        <!-- Language Switcher -->
        <div class="flex items-center gap-2">
          <div class="flex bg-surface-alt p-0.5 rounded-lg border border-border-light">
            <button class="px-2.5 py-1 text-xs font-bold rounded-md bg-white shadow-sm text-primary">EN</button>
            <button class="px-2.5 py-1 text-xs font-bold rounded-md text-text-muted hover:bg-white/60 transition-all">AR</button>
          </div>
        </div>

        <!-- Mobile Menu Toggle -->
        <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg hover:bg-surface-hover transition-colors" aria-label="Toggle menu">
          <svg class="w-5 h-5 text-text" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </nav>

      <!-- Mobile Navigation -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-border-light bg-white/95 backdrop-blur-xl">
        <div class="px-4 py-3 space-y-1">
          {navItems.map(item => (
            <a
              href={item.href}
              class:list={[
                'block px-3 py-2.5 rounded-lg text-sm font-semibold transition-all no-underline',
                currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
                  ? 'bg-primary/8 text-primary'
                  : 'text-text-secondary hover:bg-surface-hover'
              ]}
            >
              <span class="mr-2">{item.icon}</span>{item.label}
            </a>
          ))}
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-border-light bg-white/60 backdrop-blur-sm mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <nav class="flex flex-wrap gap-x-6 gap-y-2 text-sm font-medium">
            <a href="/words/" class="text-text-muted hover:text-primary transition-colors">Vocabulary</a>
            <a href="/grammar/" class="text-text-muted hover:text-primary transition-colors">Grammar</a>
            <a href="/practice/" class="text-text-muted hover:text-primary transition-colors">Practice</a>
            <a href="/contribute/" class="text-text-muted hover:text-primary transition-colors">Contribute</a>
          </nav>
          <div class="flex items-center gap-2">
            <div class="w-6 h-6 rounded-md bg-gradient-to-br from-primary to-primary-dark flex items-center justify-center">
              <span class="text-white text-[8px] font-bold">TR</span>
            </div>
            <span class="text-sm font-semibold text-text-secondary">Learn Turkish</span>
          </div>
          <p class="text-xs text-text-muted">
            Developed by <a href="https://nhussein.io" class="font-bold text-primary hover:underline">nhussein.io</a>
            · © 2026 All Rights Reserved
          </p>
          <a href="https://github.com/nhussein2026/learn-turkish" class="text-xs font-semibold text-text-muted hover:text-primary transition-colors no-underline">
            ⭐ Open Source
          </a>
        </div>
      </div>
    </footer>

    <!-- Mobile menu script -->
    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>

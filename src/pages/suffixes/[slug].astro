---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const suffixes = await getCollection('suffixes');
  return suffixes.map(s => ({
    params: { slug: s.data.id },
    props: { suffix: s.data },
  }));
}

const { suffix } = Astro.props;
---

<BaseLayout title={`${suffix.suffix} — ${suffix.title.en}`} description={`Turkish suffix "${suffix.suffix}" — ${suffix.title.en}. ${suffix.cefr} level. Vowel harmony rules and examples.`}>
  <nav class="flex items-center gap-2 text-sm text-text-muted mb-6 animate-fade-in">
    <a href="/" class="hover:text-primary transition-colors no-underline">Home</a>
    <span>›</span>
    <a href="/suffixes/" class="hover:text-primary transition-colors no-underline">Suffixes</a>
    <span>›</span>
    <span class="text-text font-semibold">{suffix.suffix}</span>
  </nav>

  <div class="max-w-4xl">
    <!-- Header -->
    <section class="glass-card p-6 md:p-8 mb-6 animate-fade-in">
      <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
        <div>
          <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-secondary mb-2">{suffix.suffix}</h1>
          <h2 class="text-xl font-bold text-text">{suffix.title.en}</h2>
          {suffix.title.ar && <p class="text-lg text-text-muted mt-1" dir="rtl">{suffix.title.ar}</p>}
        </div>
        <div class="flex flex-col items-end gap-2">
          <span class={`badge cefr-${suffix.cefr} text-sm`}>{suffix.cefr}</span>
          <span class="badge badge-secondary">{suffix.type}</span>
          {suffix.vowelHarmony && <span class="badge badge-accent">{suffix.vowelHarmony}</span>}
        </div>
      </div>

      {suffix.variants.length > 0 && (
        <div class="mt-4 p-4 rounded-xl bg-surface-alt border border-border-light">
          <div class="text-[10px] font-bold text-text-muted uppercase tracking-wider mb-2">All Variants</div>
          <div class="flex flex-wrap gap-2">
            {suffix.variants.map(v => (
              <span class="px-3 py-1.5 text-sm font-mono font-bold bg-secondary/10 text-secondary rounded-lg">{v}</span>
            ))}
          </div>
        </div>
      )}
    </section>

    <!-- English Explanation -->
    {suffix.explanation.en && (
      <section class="glass-card p-6 md:p-8 mb-6 animate-slide-up" style="animation-delay: 0.1s">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-lg">🇬🇧</span>
          <h2 class="text-xl font-bold">English Explanation</h2>
        </div>
        <div class="text-text-secondary leading-relaxed whitespace-pre-line">{suffix.explanation.en}</div>
      </section>
    )}

    <!-- Arabic Explanation -->
    {suffix.explanation.ar && (
      <section class="glass-card p-6 md:p-8 mb-6 animate-slide-up" style="animation-delay: 0.15s" dir="rtl">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-lg">🇸🇦</span>
          <h2 class="text-xl font-bold">الشرح بالعربية</h2>
        </div>
        <div class="text-text-secondary leading-relaxed whitespace-pre-line">{suffix.explanation.ar}</div>
      </section>
    )}

    <!-- Examples -->
    {suffix.examples.length > 0 && (
      <section class="glass-card p-6 md:p-8 animate-slide-up" style="animation-delay: 0.2s">
        <h2 class="text-xl font-bold mb-4">📝 Usage Examples</h2>
        <div class="space-y-3">
          {suffix.examples.map(ex => (
            <div class="p-4 rounded-xl bg-surface-alt border border-border-light">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-sm font-mono text-text-muted">{ex.base}</span>
                <span class="text-primary font-bold">→</span>
                <span class="text-lg font-bold text-secondary">{ex.result}</span>
              </div>
              {ex.meaning.en && <p class="text-sm text-text-secondary">🇬🇧 {ex.meaning.en}</p>}
              {ex.meaning.ar && <p class="text-sm text-text-secondary mt-1" dir="rtl">🇸🇦 {ex.meaning.ar}</p>}
            </div>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

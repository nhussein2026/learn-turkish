---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SuffixForm from '../../components/SuffixForm.astro';
import SentenceDisplay from '../../components/SentenceDisplay.astro';
import AgglutinationVisualizer from '../../components/AgglutinationVisualizer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const words = await getCollection('words');
  return words.map(word => ({
    params: { slug: word.data.id },
    props: { word: word.data },
  }));
}

const { word } = Astro.props;

// Fetch related data
const allSentences = await getCollection('sentences');
const exampleSentences = allSentences.filter(s =>
  word.exampleSentences.includes(s.data.id)
);

const allWords = await getCollection('words');
const relatedWords = allWords.filter(w =>
  word.relatedWords.includes(w.data.id)
);
---

<BaseLayout title={`${word.turkish} — ${word.translations.en}`} description={`Learn the Turkish word "${word.turkish}" (${word.translations.en}). ${word.pos}, ${word.cefr} level. Full morphology, suffixes, and examples.`}>
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-text-muted mb-6 animate-fade-in">
    <a href="/" class="hover:text-primary transition-colors no-underline">Home</a>
    <span>›</span>
    <a href="/words/" class="hover:text-primary transition-colors no-underline">Vocabulary</a>
    <span>›</span>
    <span class="text-text font-semibold">{word.turkish}</span>
  </nav>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Main Content -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Word Header -->
      <section class="glass-card p-6 md:p-8 animate-fade-in">
        <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
          <div>
            <div class="flex items-center gap-3 mb-2">
              <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight gradient-text">{word.turkish}</h1>
              <button 
                id="copy-yaml-btn" 
                class="p-2 rounded-lg bg-surface-alt hover:bg-surface-hover text-text-muted transition-colors"
                title="Copy YAML Source"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
              </button>
            </div>
            {word.root && (
              <p class="text-sm text-text-muted">Root: <strong class="text-text">{word.root}</strong></p>
            )}
          </div>
          <div class="flex flex-col items-end gap-2">
            <span class={`badge cefr-${word.cefr} text-sm`}>{word.cefr}</span>
            <span class={`badge pos-${word.pos}`}>{word.pos}</span>
            {word.frequencyRank && (
              <span class="badge badge-accent">Rank #{word.frequencyRank}</span>
            )}
          </div>
        </div>

        <!-- Translations -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-6">
          {word.translations.en && (
            <div class="p-4 rounded-xl bg-blue-50 border border-blue-100">
              <div class="text-[10px] font-bold text-blue-400 uppercase tracking-wider mb-1">English</div>
              <div class="text-lg font-bold text-blue-900">{word.translations.en}</div>
            </div>
          )}
          {word.translations.ar && (
            <div class="p-4 rounded-xl bg-emerald-50 border border-emerald-100" dir="rtl">
              <div class="text-[10px] font-bold text-emerald-400 uppercase tracking-wider mb-1">العربية</div>
              <div class="text-lg font-bold text-emerald-900">{word.translations.ar}</div>
            </div>
          )}
        </div>
      </section>

      <!-- Morphology / Suffix Examples -->
      {word.morphology && word.morphology.suffixExamples.length > 0 && (
        <section class="animate-slide-up" style="animation-delay: 0.1s">
          <div class="flex items-center justify-between mb-6">
            <div>
              <h2 class="text-xl font-bold">🔗 Suffix Breakdown</h2>
              <p class="text-sm text-text-muted mt-1">Agglutination visualizer for <strong>{word.turkish}</strong></p>
            </div>
          </div>
          
          <AgglutinationVisualizer 
            root={word.morphology.root} 
            forms={word.morphology.suffixExamples} 
          />
        </section>
      )}

      <!-- Conjugation Info -->
      {word.morphology?.conjugation && (
        <section class="glass-card p-6 animate-slide-up" style="animation-delay: 0.15s">
          <h2 class="text-xl font-bold mb-4">📝 Conjugation</h2>
          <div class="flex flex-wrap gap-3">
            <div class="p-3 rounded-xl bg-surface-alt border border-border-light">
              <div class="text-[10px] font-bold text-text-muted uppercase tracking-wider mb-1">Type</div>
              <div class="text-sm font-bold text-text">{word.morphology.conjugation.type}</div>
            </div>
            {word.morphology.conjugation.group && (
              <div class="p-3 rounded-xl bg-surface-alt border border-border-light">
                <div class="text-[10px] font-bold text-text-muted uppercase tracking-wider mb-1">Group</div>
                <div class="text-sm font-bold text-text">{word.morphology.conjugation.group}</div>
              </div>
            )}
          </div>
        </section>
      )}

      <!-- Example Sentences -->
      {exampleSentences.length > 0 && (
        <section class="glass-card p-6 md:p-8 animate-slide-up" style="animation-delay: 0.2s">
          <h2 class="text-xl font-bold mb-1">💬 Example Sentences</h2>
          <p class="text-sm text-text-muted mb-5">Real Turkish sentences using this word</p>
          <div class="space-y-4">
            {exampleSentences.map(s => (
              <SentenceDisplay sentence={s.data} />
            ))}
          </div>
        </section>
      )}
    </div>

    <!-- Sidebar -->
    <aside class="space-y-6">
      <!-- Tags -->
      {word.tags.length > 0 && (
        <div class="glass-card p-5 animate-slide-up" style="animation-delay: 0.25s">
          <h3 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-3">Tags</h3>
          <div class="flex flex-wrap gap-1.5">
            {word.tags.map(tag => (
              <span class="badge badge-primary">{tag}</span>
            ))}
          </div>
        </div>
      )}

      <!-- Categories -->
      {word.categories.length > 0 && (
        <div class="glass-card p-5 animate-slide-up" style="animation-delay: 0.3s">
          <h3 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-3">Categories</h3>
          <div class="flex flex-wrap gap-1.5">
            {word.categories.map(cat => (
              <span class="badge badge-accent">{cat}</span>
            ))}
          </div>
        </div>
      )}

      <!-- Related Words -->
      {relatedWords.length > 0 && (
        <div class="glass-card p-5 animate-slide-up" style="animation-delay: 0.35s">
          <h3 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-3">Related Words</h3>
          <div class="space-y-2">
            {relatedWords.map(rw => (
              <a href={`/words/${rw.data.id}/`} class="block p-3 rounded-lg bg-surface-alt hover:bg-surface-hover border border-border-light transition-colors no-underline">
                <span class="font-bold text-sm text-text">{rw.data.turkish}</span>
                <span class="text-xs text-text-muted ml-2">{rw.data.translations.en}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Quick Info -->
      <div class="glass-card p-5 animate-slide-up" style="animation-delay: 0.4s">
        <h3 class="text-sm font-bold text-text-muted uppercase tracking-wider mb-3">Quick Info</h3>
        <dl class="space-y-3 text-sm">
          <div class="flex justify-between">
            <dt class="text-text-muted">Part of Speech</dt>
            <dd class="font-semibold text-text">{word.pos}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-text-muted">CEFR Level</dt>
            <dd class="font-semibold text-text">{word.cefr}</dd>
          </div>
          {word.frequencyRank && (
            <div class="flex justify-between">
              <dt class="text-text-muted">Frequency</dt>
              <dd class="font-semibold text-text">#{word.frequencyRank}</dd>
            </div>
          )}
          {word.morphology?.root && (
            <div class="flex justify-between">
              <dt class="text-text-muted">Root</dt>
              <dd class="font-semibold text-primary">{word.morphology.root}</dd>
            </div>
          )}
          <div class="flex justify-between">
            <dt class="text-text-muted">Verified</dt>
            <dd class="font-semibold">{word.meta.verified ? '✅ Yes' : '⏳ Pending'}</dd>
          </div>
        </dl>
      </div>
    </aside>
  </div>
</BaseLayout>

<script define:vars={{ word }}>
  document.getElementById('copy-yaml-btn')?.addEventListener('click', () => {
    const yaml = `id: ${word.id}
turkish: ${word.turkish}
pos: ${word.pos}
cefr: ${word.cefr}
translations:
  en: "${word.translations.en}"
  ar: "${word.translations.ar || ''}"
root: "${word.root || ''}"
relatedWords: ${JSON.stringify(word.relatedWords)}
tags: ${JSON.stringify(word.tags)}
categories: ${JSON.stringify(word.categories)}
meta:
  contributor: "${word.meta.contributor}"
  verified: ${word.meta.verified}
  lastUpdated: "${word.meta.lastUpdated}"`;

    navigator.clipboard.writeText(yaml);
    const btn = document.getElementById('copy-yaml-btn');
    const originalHtml = btn.innerHTML;
    btn.innerHTML = '✓';
    btn.classList.add('text-success');
    setTimeout(() => {
      btn.innerHTML = originalHtml;
      btn.classList.remove('text-success');
    }, 2000);
  });
</script>


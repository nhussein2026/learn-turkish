---
import Layout from '../layouts/Layout.astro';
import SkillCard from '../components/SkillCard.astro';

const skills = [
  { title: 'Reading', titleTr: 'Okuma', icon: '📖', color: '#E30A17', progress: 45 },
  { title: 'Writing', titleTr: 'Yazma', icon: '✍️', color: '#00B5E2', progress: 30 },
  { title: 'Listening', titleTr: 'Dinleme', icon: '🎧', color: '#C5A059', progress: 20 },
  { title: 'Speaking', titleTr: 'Konuşma', icon: '🗣️', color: '#1B9C85', progress: 15 },
  { title: 'Grammar', titleTr: 'Dil Bilgisi', icon: '📐', color: '#6C4AB6', progress: 60 },
  { title: 'Vocabulary', titleTr: 'Kelime Bilgisi', icon: '📚', color: '#FF7B54', progress: 50 },
];
---

<Layout title="Dashboard">
	<div class="mb-12">
    <div class="flex items-center gap-2 mb-2">
      <span class="px-2 py-0.5 bg-primary/10 text-primary text-[10px] font-bold rounded uppercase tracking-widest">Level A1</span>
      <span class="text-text-muted text-xs font-semibold">Starter Phase</span>
    </div>
		<h2 class="text-4xl font-extrabold mb-2">Merhaba, Naser. <span class="text-primary">Hoş Geldiniz!</span></h2>
		<p class="text-text-secondary text-lg max-w-2xl">
      Continue your Turkish journey from <span class="font-bold">English</span> or <span class="font-bold">Arabic</span>. 
      Work on all skills in parallel to achieve mastery.
    </p>
	</div>

	<section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
    {skills.map(skill => (
      <SkillCard {...skill} />
    ))}
	</section>

	<div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
    <!-- Resources Section -->
    <section>
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-2xl font-bold">Latest Resources</h3>
        <a href="/resources" class="text-primary font-bold text-sm hover:underline">View All</a>
      </div>
      <div class="space-y-4">
        <div class="glass p-4 rounded-lg flex items-center justify-between hover:bg-white/50 transition-colors cursor-pointer">
          <div class="flex items-center gap-4">
            <div class="text-2xl">📄</div>
            <div>
              <h4 class="font-bold text-sm">Turkish Grammar Essentials</h4>
              <p class="text-xs text-text-muted">PDF Resource • 1.2MB</p>
            </div>
          </div>
          <span class="text-xs font-bold text-primary px-2 py-1 bg-primary/5 rounded">Download</span>
        </div>
        <div class="glass p-4 rounded-lg flex items-center justify-between hover:bg-white/50 transition-colors cursor-pointer opacity-70">
          <div class="flex items-center gap-4">
            <div class="text-2xl">📄</div>
            <div>
              <h4 class="font-bold text-sm">Most Common 1000 Words</h4>
              <p class="text-xs text-text-muted">PDF Resource • Missing</p>
            </div>
          </div>
          <span class="text-xs font-bold text-text-muted px-2 py-1 bg-border/20 rounded">Pending Restore</span>
        </div>
      </div>
    </section>

    <!-- Interactive Features Placeholder -->
    <section>
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-2xl font-bold">Practice Center</h3>
        <span class="text-text-muted text-xs font-bold uppercase tracking-widest">Coming Soon</span>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div class="glass p-6 rounded-lg text-center opacity-75 border-dashed border-2">
          <div class="text-3xl mb-3">🃏</div>
          <h4 class="font-bold text-sm">Flashcards</h4>
          <p class="text-[10px] text-text-muted mt-2">Personalized spaced repetition for vocabulary.</p>
        </div>
        <div class="glass p-6 rounded-lg text-center opacity-75 border-dashed border-2">
          <div class="text-3xl mb-3">🎯</div>
          <h4 class="font-bold text-sm">Skill Quizzes</h4>
          <p class="text-[10px] text-text-muted mt-2">Test your level after each lesson modules.</p>
        </div>
      </div>
    </section>
  </div>

  <style>
    .grid { display: grid; }
    .grid-cols-1 { grid-template-columns: repeat(1, minmax(0, 1fr)); }
    @media (min-width: 768px) { .md\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    @media (min-width: 1024px) { 
      .lg\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); } 
      .lg\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    .gap-6 { gap: 1.5rem; }
    .gap-10 { gap: 2.5rem; }
    .gap-4 { gap: 1rem; }
    .mb-12 { margin-bottom: 3rem; }
    .mb-2 { margin-bottom: 0.5rem; }
    .mb-6 { margin-bottom: 1.5rem; }
    .mb-16 { margin-bottom: 4rem; }
    .mt-6 { margin-top: 1.5rem; }
    .p-4 { padding: 1rem; }
    .p-6 { padding: 1.5rem; }
    .text-4xl { font-size: 2.25rem; line-height: 2.5rem; }
    .text-2xl { font-size: 1.5rem; line-height: 2rem; }
    .text-lg { font-size: 1.125rem; line-height: 1.75rem; }
    .text-sm { font-size: 0.875rem; line-height: 1.25rem; }
    .text-xs { font-size: 0.75rem; line-height: 1rem; }
    .font-extrabold { font-weight: 800; }
    .max-w-2xl { max-width: 42rem; }
    .opacity-70 { opacity: 0.7; }
    .opacity-75 { opacity: 0.75; }
    .border-dashed { border-style: dashed; }
    .border-2 { border-width: 2px; }
  </style>
</Layout>

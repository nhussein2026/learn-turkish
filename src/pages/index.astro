---
import BaseLayout from '../layouts/BaseLayout.astro';
import WordCard from '../components/WordCard.astro';
import { getCollection } from 'astro:content';

const words = await getCollection('words');
const sentences = await getCollection('sentences');
const grammarRules = await getCollection('grammar');
const suffixList = await getCollection('suffixes');

const stats = [
  { label: 'Words', value: words.length, icon: '📚', color: 'primary' },
  { label: 'Sentences', value: sentences.length, icon: '💬', color: 'secondary' },
  { label: 'Grammar Rules', value: grammarRules.length, icon: '📐', color: 'accent' },
  { label: 'Suffixes', value: suffixList.length, icon: '🔗', color: 'success' },
];

const recentWords = words
  .sort((a, b) => (a.data.frequencyRank ?? 999) - (b.data.frequencyRank ?? 999))
  .slice(0, 6);

const cefrGroups = ['A1', 'A2', 'B1', 'B2', 'C1', 'C2'];
const wordsByLevel = cefrGroups.map(level => ({
  level,
  count: words.filter(w => w.data.cefr === level).length,
}));
---

<BaseLayout title="Home" description="Learn Turkish — A data-driven Turkish language learning platform for English and Arabic speakers">
  <!-- Hero Section -->
  <section class="py-12 md:py-20 animate-fade-in">
    <div class="max-w-3xl">
      <div class="flex items-center gap-2 mb-4">
        <span class="badge badge-primary">Open Source</span>
        <span class="badge badge-accent">Multilingual</span>
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mb-4 leading-[1.1]">
        Master <span class="gradient-text">Turkish</span> Through Structured Learning
      </h1>
      <p class="text-lg text-text-secondary leading-relaxed mb-8 max-w-2xl">
        A comprehensive, data-driven platform for learning Turkish from
        <strong>English</strong> or <strong>Arabic</strong>. Explore vocabulary with morphology,
        grammar rules, suffix trees, and real-world sentences.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/words/" class="btn btn-primary">
          📚 Explore Vocabulary
        </a>
        <a href="/grammar/" class="btn btn-secondary">
          📐 Learn Grammar
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Grid -->
  <section class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16 animate-slide-up" style="animation-delay: 0.1s">
    {stats.map(stat => (
      <div class="glass-card p-5 text-center">
        <div class="text-2xl mb-2">{stat.icon}</div>
        <div class="text-3xl font-extrabold text-text mb-1">{stat.value}</div>
        <div class="text-xs font-semibold text-text-muted uppercase tracking-wider">{stat.label}</div>
      </div>
    ))}
  </section>

  <!-- Most Common Words -->
  <section class="mb-16 animate-slide-up" style="animation-delay: 0.2s">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="text-2xl font-bold">Most Common Words</h2>
        <p class="text-sm text-text-muted mt-1">Start with the highest frequency words</p>
      </div>
      <a href="/words/" class="text-sm font-bold text-primary hover:underline no-underline">View All →</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {recentWords.map(word => (
        <WordCard word={word.data} />
      ))}
    </div>
  </section>

  <!-- Start Practicing Section -->
  <section class="mb-16 animate-slide-up" style="animation-delay: 0.25s">
    <div class="glass-card p-8 bg-gradient-to-br from-primary to-primary-dark text-white border-none shadow-glow">
      <div class="flex flex-col md:flex-row items-center gap-8">
        <div class="flex-1">
          <div class="inline-block px-3 py-1 rounded-full bg-white/20 text-xs font-bold uppercase tracking-widest mb-4">New Feature</div>
          <h2 class="text-3xl font-extrabold mb-4">Test Your Knowledge</h2>
          <p class="text-white/80 text-lg mb-8 leading-relaxed">
            Ready to master Turkish? Try our interactive flashcards and quizzes. 
            Track your progress and climb the ranks!
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/practice/flashcards/" class="btn bg-white text-primary hover:bg-white/90">📇 Start Flashcards</a>
            <a href="/practice/quiz/" class="btn border-2 border-white/30 text-white hover:bg-white/10">✅ Take a Quiz</a>
          </div>
        </div>
        <div class="text-8xl opacity-30 select-none animate-pulse">🎯</div>
      </div>
    </div>
  </section>

  <!-- CEFR Progress -->
  <section class="mb-16 animate-slide-up" style="animation-delay: 0.3s">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="text-2xl font-bold">Words by Level</h2>
        <p class="text-sm text-text-muted mt-1">CEFR proficiency distribution</p>
      </div>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
      {wordsByLevel.map(({ level, count }) => (
        <div class="glass-card p-4 text-center">
          <span class={`badge cefr-${level} mb-2`}>{level}</span>
          <div class="text-2xl font-extrabold text-text">{count}</div>
          <div class="text-[10px] font-semibold text-text-muted uppercase">words</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Quick Links -->
  <section class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16 animate-slide-up" style="animation-delay: 0.4s">
    <a href="/suffixes/" class="glass-card p-6 no-underline group block">
      <div class="flex items-center gap-4 mb-3">
        <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center text-2xl">🔗</div>
        <div>
          <h3 class="text-lg font-bold text-text group-hover:text-secondary transition-colors">Turkish Suffixes</h3>
          <p class="text-sm text-text-muted">The building blocks of agglutination</p>
        </div>
      </div>
      <p class="text-sm text-text-secondary">
        Explore {suffixList.length} suffixes with vowel harmony rules, variants, and examples.
        Understanding suffixes is key to mastering Turkish.
      </p>
    </a>
    <a href="/grammar/" class="glass-card p-6 no-underline group block">
      <div class="flex items-center gap-4 mb-3">
        <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center text-2xl">📐</div>
        <div>
          <h3 class="text-lg font-bold text-text group-hover:text-accent-dark transition-colors">Grammar Rules</h3>
          <p class="text-sm text-text-muted">Structured explanations in EN & AR</p>
        </div>
      </div>
      <p class="text-sm text-text-secondary">
        {grammarRules.length} grammar rules with bilingual explanations, linked suffixes, and real example sentences.
      </p>
    </a>
  </section>
</BaseLayout>


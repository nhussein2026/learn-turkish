---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SentenceBuilder from '../../components/practice/SentenceBuilder.tsx';
import { getCollection } from 'astro:content';

const allSentences = await getCollection('sentences');

// Shuffle and prepare sentence data
const sentences = allSentences
  .sort(() => Math.random() - 0.5)
  .slice(0, 10) // 10 sentences per session
  .map(s => ({
    id: s.data.id,
    turkish: s.data.turkish,
    en: s.data.translations.en,
    ar: s.data.translations.ar,
    cefr: s.data.cefr
  }));
---

<BaseLayout title="Sentence Builder" description="Master Turkish word order by building sentences from jumbled words.">
  <section class="max-w-4xl mx-auto mb-8 animate-fade-in">
    <div class="flex items-center gap-4 mb-4">
      <a href="/practice/" class="p-2 rounded-lg hover:bg-surface-hover text-text-muted transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
      </a>
      <h1 class="text-3xl font-extrabold tracking-tight">
        🏗️ <span class="gradient-text">Sentence Builder</span>
      </h1>
    </div>
    <p class="text-text-secondary text-center max-w-xl mx-auto">
      Order the Turkish words correctly to match the English translation. Pay attention to SOV order!
    </p>
  </section>

  <SentenceBuilder client:load sentences={sentences} />
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const grammarRules = await getCollection('grammar');
const sorted = grammarRules.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Grammar" description="Turkish grammar rules explained in English and Arabic — tenses, cases, suffixes, and more">
  <section class="mb-8 animate-fade-in">
    <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-2">
      📐 <span class="gradient-text">Grammar</span>
    </h1>
    <p class="text-text-secondary text-base max-w-2xl">
      {grammarRules.length} grammar rules explained in English and Arabic, with linked suffixes and real example sentences.
    </p>
  </section>

  <div class="space-y-4 animate-slide-up" style="animation-delay: 0.1s">
    {sorted.map((rule, i) => (
      <a href={`/grammar/${rule.data.id}/`} class="glass-card p-6 block no-underline group">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-2">
              <span class="w-8 h-8 rounded-lg bg-accent/10 flex items-center justify-center text-sm font-bold text-accent-dark">{i + 1}</span>
              <h2 class="text-lg font-bold text-text group-hover:text-primary transition-colors">
                {rule.data.title.en}
              </h2>
            </div>
            {rule.data.title.ar && (
              <p class="text-sm text-text-muted mr-11" dir="rtl">{rule.data.title.ar}</p>
            )}
            <div class="flex flex-wrap gap-2 mt-3 ml-11">
              <span class={`badge cefr-${rule.data.cefr}`}>{rule.data.cefr}</span>
              {rule.data.tags.map(tag => (
                <span class="badge badge-primary">{tag}</span>
              ))}
              {rule.data.suffixes.length > 0 && (
                <span class="badge badge-secondary">{rule.data.suffixes.length} suffix(es)</span>
              )}
              {rule.data.examples.length > 0 && (
                <span class="badge badge-accent">{rule.data.examples.length} example(s)</span>
              )}
            </div>
          </div>
          <span class="text-text-muted group-hover:text-primary transition-colors text-lg">→</span>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>

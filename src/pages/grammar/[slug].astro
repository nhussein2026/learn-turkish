---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const grammar = await getCollection('grammar');
  return grammar.map(rule => ({
    params: { slug: rule.data.id },
    props: { rule: rule.data },
  }));
}

const { rule } = Astro.props;

const allSentences = await getCollection('sentences');
const examples = allSentences.filter(s => rule.examples.includes(s.data.id));

const allSuffixes = await getCollection('suffixes');
const linkedSuffixes = allSuffixes.filter(s => rule.suffixes.includes(s.data.id));
---

<BaseLayout title={rule.title.en || rule.id} description={`Turkish grammar: ${rule.title.en}. ${rule.cefr} level explanation in English and Arabic.`}>
  <nav class="flex items-center gap-2 text-sm text-text-muted mb-6 animate-fade-in">
    <a href="/" class="hover:text-primary transition-colors no-underline">Home</a>
    <span>›</span>
    <a href="/grammar/" class="hover:text-primary transition-colors no-underline">Grammar</a>
    <span>›</span>
    <span class="text-text font-semibold">{rule.title.en}</span>
  </nav>

  <div class="max-w-4xl">
    <!-- Header -->
    <section class="glass-card p-6 md:p-8 mb-6 animate-fade-in">
      <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
        <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight gradient-text">{rule.title.en}</h1>
        <span class={`badge cefr-${rule.cefr} text-sm`}>{rule.cefr}</span>
      </div>
      {rule.title.ar && (
        <p class="text-xl font-bold text-text-secondary" dir="rtl">{rule.title.ar}</p>
      )}
      <div class="flex flex-wrap gap-2 mt-4">
        {rule.tags.map(tag => (
          <span class="badge badge-primary">{tag}</span>
        ))}
      </div>
    </section>

    <!-- English Explanation -->
    {rule.explanation.en && (
      <section class="glass-card p-6 md:p-8 mb-6 animate-slide-up" style="animation-delay: 0.1s">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-lg">🇬🇧</span>
          <h2 class="text-xl font-bold">English Explanation</h2>
        </div>
        <div class="prose prose-sm max-w-none text-text-secondary leading-relaxed whitespace-pre-line">
          {rule.explanation.en}
        </div>
      </section>
    )}

    <!-- Arabic Explanation -->
    {rule.explanation.ar && (
      <section class="glass-card p-6 md:p-8 mb-6 animate-slide-up" style="animation-delay: 0.15s" dir="rtl">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-lg">🇸🇦</span>
          <h2 class="text-xl font-bold">الشرح بالعربية</h2>
        </div>
        <div class="prose prose-sm max-w-none text-text-secondary leading-relaxed whitespace-pre-line">
          {rule.explanation.ar}
        </div>
      </section>
    )}

    <!-- Linked Suffixes -->
    {linkedSuffixes.length > 0 && (
      <section class="glass-card p-6 md:p-8 mb-6 animate-slide-up" style="animation-delay: 0.2s">
        <h2 class="text-xl font-bold mb-4">🔗 Related Suffixes</h2>
        <div class="space-y-3">
          {linkedSuffixes.map(s => (
            <a href={`/suffixes/${s.data.id}/`} class="block p-4 rounded-xl bg-surface-alt border border-border-light hover:border-secondary/30 transition-colors no-underline">
              <div class="flex items-center justify-between">
                <div>
                  <span class="text-lg font-bold text-secondary">{s.data.suffix}</span>
                  <span class="text-sm text-text-muted ml-2">{s.data.title.en}</span>
                </div>
                <span class={`badge cefr-${s.data.cefr}`}>{s.data.cefr}</span>
              </div>
              {s.data.variants.length > 0 && (
                <div class="flex gap-1 mt-2">
                  {s.data.variants.map(v => (
                    <span class="badge badge-secondary">{v}</span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Example Sentences -->
    {examples.length > 0 && (
      <section class="glass-card p-6 md:p-8 animate-slide-up" style="animation-delay: 0.25s">
        <h2 class="text-xl font-bold mb-4">💬 Example Sentences</h2>
        <div class="space-y-4">
          {examples.map(s => (
            <div class="p-4 rounded-xl bg-surface-alt border border-border-light">
              <p class="text-base font-semibold text-text mb-2">{s.data.turkish}</p>
              {s.data.translations.en && <p class="text-sm text-text-secondary">🇬🇧 {s.data.translations.en}</p>}
              {s.data.translations.ar && <p class="text-sm text-text-secondary mt-1" dir="rtl">🇸🇦 {s.data.translations.ar}</p>}
            </div>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

---
interface Props {
  form: string;
  suffixes: string[];
  meaning: {
    en?: string;
    ar?: string;
  };
}

const { form, suffixes, meaning } = Astro.props;
---

<div class="p-4 rounded-xl bg-surface-alt border border-border-light hover:border-secondary/30 transition-all group/suffix">
  <div class="flex flex-wrap items-center gap-3 mb-3">
    <span class="text-xl font-bold text-primary group-hover/suffix:scale-105 transition-transform origin-left">
      {form}
    </span>
    <div class="flex gap-1">
      {suffixes.map(s => (
        <span class="badge badge-secondary font-mono tracking-tighter">{s}</span>
      ))}
    </div>
  </div>
  
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm border-t border-border-light/40 pt-2">
    {meaning.en && (
      <span class="text-text-secondary flex items-center gap-1.5">
        <span class="text-[10px] grayscale opacity-50">🇬🇧</span> {meaning.en}
      </span>
    )}
    {meaning.ar && (
      <span class="text-text-secondary flex items-center gap-1.5 justify-end" dir="rtl">
        <span class="text-[10px] grayscale opacity-50 ml-1.5">🇸🇦</span> {meaning.ar}
      </span>
    )}
  </div>
</div>

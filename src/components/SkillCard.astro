---
interface Props {
	title: string;
	titleTr: string;
	icon: string;
	color: string;
	progress: number;
}

const { title, titleTr, icon, color, progress } = Astro.props;
---

<div class="glass p-6 rounded-lg hover:shadow-lg transition-all border-l-4 group cursor-pointer" style={`border-left-color: ${color}`}>
	<div class="flex justify-between items-start mb-4">
		<div class={`w-12 h-12 rounded-full flex items-center justify-center bg-opacity-20`} style={`background-color: ${color}33`}>
			<span class="text-2xl" style={`color: ${color}`}>{icon}</span>
		</div>
		<div class="text-right">
			<span class="text-xs font-bold text-text-muted">{titleTr}</span>
			<h3 class="text-lg font-bold group-hover:text-primary transition-colors">{title}</h3>
		</div>
	</div>
	
	<div class="mt-6">
		<div class="flex justify-between items-center mb-1">
			<span class="text-xs font-semibold text-text-secondary">Progress</span>
			<span class="text-xs font-bold text-primary">{progress}%</span>
		</div>
		<div class="h-2 bg-border/30 rounded-full overflow-hidden">
			<div class="h-full transition-all duration-500" style={`width: ${progress}%; background-color: ${color}`}></div>
		</div>
	</div>
</div>

---
import type { Word } from '../schemas/word';

interface Props {
  word: Word;
  showDetails?: boolean;
}

const { word, showDetails = false } = Astro.props;
---

<div
  class="glass-card p-5 no-underline group block h-full flex flex-col relative overflow-hidden"
  data-word-id={word.id}
  data-turkish={word.turkish}
>
  <!-- Interactive Overlay -->
  <div class="absolute top-3 right-3 flex gap-2 z-10">
    <button 
      class="listen-btn p-2 rounded-full bg-white/50 hover:bg-white hover:text-secondary shadow-sm transition-all text-text-muted"
      title="Listen"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
      </svg>
    </button>
    <button 
      class="master-btn p-2 rounded-full bg-white/50 hover:bg-white shadow-sm transition-all text-text-muted"
      title="Mark as Mastered"
    >
      <svg class="w-4 h-4 check-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
    </button>
  </div>

  <a href={`/words/${word.id}/`} class="no-underline block flex-1">
    <div class="flex items-start justify-between mb-2 pr-16">
      <h3 class="text-lg font-bold text-text group-hover:text-primary transition-colors leading-tight">
        {word.turkish}
      </h3>
    </div>

    <p class="text-sm text-text-secondary mb-1">{word.translations.en}</p>
    {word.translations.ar && (
      <p class="text-sm text-text-muted mb-2" dir="rtl">{word.translations.ar}</p>
    )}

    <div class="mt-auto flex items-center gap-2 pt-3 border-t border-border-light">
      <span class={`badge cefr-${word.cefr} shrink-0`}>{word.cefr}</span>
      <span class={`badge pos-${word.pos}`}>{word.pos}</span>
      {word.frequencyRank && (
        <span class="text-[10px] font-bold text-accent-dark ml-auto">#{word.frequencyRank}</span>
      )}
    </div>
  </a>
</div>

<script>
  import { toggleMasteredWord, isWordMastered } from '../lib/stores/progress';

  function initCard(card: HTMLElement) {
    const wordId = card.dataset.wordId!;
    const turkish = card.dataset.turkish!;
    const masterBtn = card.querySelector('.master-btn') as HTMLButtonElement;
    const listenBtn = card.querySelector('.listen-btn') as HTMLButtonElement;

    // Initial state
    if (isWordMastered(wordId)) {
      masterBtn.classList.add('bg-success', 'text-white');
      masterBtn.classList.remove('bg-white/50', 'text-text-muted');
    }

    masterBtn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const isNowMastered = toggleMasteredWord(wordId);
      if (isNowMastered) {
        masterBtn.classList.add('bg-success', 'text-white');
        masterBtn.classList.remove('bg-white/50', 'text-text-muted');
      } else {
        masterBtn.classList.remove('bg-success', 'text-white');
        masterBtn.classList.add('bg-white/50', 'text-text-muted');
      }
    });

    listenBtn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const utterance = new SpeechSynthesisUtterance(turkish);
      utterance.lang = 'tr-TR';
      utterance.rate = 0.9;
      window.speechSynthesis.speak(utterance);
    });
  }

  // Initialize all cards on page load
  document.querySelectorAll('[data-word-id]').forEach(el => initCard(el as HTMLElement));
  
  // Also re-init on dynamic updates (like search results)
  window.addEventListener('progress-update', () => {
    document.querySelectorAll('[data-word-id]').forEach(el => {
      const card = el as HTMLElement;
      const wordId = card.dataset.wordId!;
      const masterBtn = card.querySelector('.master-btn') as HTMLButtonElement;
      if (isWordMastered(wordId)) {
        masterBtn.classList.add('bg-success', 'text-white');
        masterBtn.classList.remove('bg-white/50', 'text-text-muted');
      } else {
        masterBtn.classList.remove('bg-success', 'text-white');
        masterBtn.classList.add('bg-white/50', 'text-text-muted');
      }
    });
  });
</script>

